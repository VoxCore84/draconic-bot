# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_token_here

# --- Channel IDs (right-click channel in Discord → Copy Channel ID) ---
# The bot watches these channels for auto-responses
CHANNEL_TROUBLESHOOTING=
CHANNEL_BUGREPORT=
CHANNEL_TWW=
CHANNEL_GENERAL=
CHANNEL_ANNOUNCEMENTS=

# --- SOAP (worldserver remote commands) ---
SOAP_HOST=127.0.0.1
SOAP_PORT=7878
SOAP_USER=1#1
SOAP_PASS=gm

# --- MySQL (for creature lookups) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=admin

# --- Wago CSV directory (auto-detected if blank) ---
# Leave blank to auto-detect from wago_common.py
WAGO_CSV_DIR=

# --- GitHub (for build watchdog) ---
# Uses gh CLI auth by default; set a PAT here for API-only mode
GITHUB_TOKEN=

# --- Build watchdog interval (seconds) ---
WATCHDOG_INTERVAL=300
