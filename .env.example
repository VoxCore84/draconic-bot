# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_token_here

# --- Channel IDs (right-click channel in Discord -> Copy Channel ID) ---
# The bot watches these channels for auto-responses
CHANNEL_TROUBLESHOOTING=
CHANNEL_BUGREPORT=
CHANNEL_TWW=
CHANNEL_GENERAL=
CHANNEL_ANNOUNCEMENTS=

# --- SOAP (worldserver remote commands — currently unused) ---
# SOAP_HOST=127.0.0.1
# SOAP_PORT=7878
# SOAP_USER=1#1
# SOAP_PASS=gm

# --- GitHub (for build watchdog) ---
GITHUB_TOKEN=
WATCHDOG_INTERVAL=300

# ===========================================================================
# AI CONFIGURATION (Gemini-powered support — v3)
# ===========================================================================

# Master switch — set to true to enable AI-powered responses
AI_ENABLED=false

# --- Google Gemini / Vertex AI ---
# Option A: Vertex AI (recommended — uses GCP billing / $300 free credits)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: Gemini Developer API (simpler, uses API key directly)
# GOOGLE_API_KEY=your-gemini-api-key

# --- Model selection ---
AI_ROUTE_DEFAULT_MODEL=gemini-2.5-flash-lite
AI_ROUTE_COMPLEX_MODEL=gemini-2.5-flash
AI_ROUTE_PRO_MODEL=gemini-2.5-pro

# --- Channel allowlists (comma-separated channel IDs) ---
# AI only responds in these channels. Leave blank = all support channels.
AI_ALLOWED_CHANNEL_IDS=
AI_TEST_CHANNEL_IDS=

# --- Cost caps ---
AI_DAILY_HARD_CAP_USD=1.50
AI_MONTHLY_SOFT_CAP_USD=20.00

# --- Timeouts ---
AI_RESPONSE_TIMEOUT_SECONDS=20

# --- Session memory ---
AI_SESSION_TTL_MINUTES=30

# --- Logging ---
AI_LOG_PREVIEW_ENABLED=true

# --- Pro tier escalation ---
AI_PRO_ESCALATION_ENABLED=true
AI_PRO_ESCALATION_DAILY_MAX=25
