# ==============================================================================
# DraconicBot — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# The .env file must be in the bot's root directory (next to __main__.py)
# or at /opt/draconic-bot/.env when deployed via systemd.
#
# SECURITY: Never commit .env to git. It contains secrets.
# ==============================================================================

# --- Required ---

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_token_here

# --- Channel IDs (right-click channel in Discord -> Copy Channel ID) ---
# The bot watches these channels for FAQ auto-responses, triage, etc.
# Leave blank to disable that channel's features.

CHANNEL_TROUBLESHOOTING=
CHANNEL_BUGREPORT=
CHANNEL_TWW=
CHANNEL_GENERAL=
CHANNEL_ANNOUNCEMENTS=

# Expansion-specific channels (FAQ + triage auto-respond here too)
CHANNEL_CLASSIC=
CHANNEL_BURNING_CRUSADE=
CHANNEL_WOTLK=
CHANNEL_CATACLYSM=
CHANNEL_MOP=
CHANNEL_WOD=
CHANNEL_LEGION=
CHANNEL_BFA=
CHANNEL_SHADOWLANDS=
CHANNEL_DRAGONFLIGHT=
CHANNEL_MIDNIGHT=

# --- Optional: GitHub (for build watchdog cog) ---
# Uses GitHub API to monitor TrinityCore commits.
# A fine-grained PAT with public_repo read access is sufficient.
GITHUB_TOKEN=

# Build watchdog poll interval in seconds (default: 300 = 5 minutes)
WATCHDOG_INTERVAL=300

